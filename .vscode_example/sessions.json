{
  "$schema": "https://cdn.statically.io/gh/nguyenngoclongdev/cdn/main/schema/v11/terminal-keeper.json",
  "theme": "tribe",
  "noClear": true,
  "active": "default",
  "activateOnStartup": true,
  "keepExistingTerminals": false,
  "sessions": {
    "default": [
      [
        {
          "name": "frontend",
          "commands": ["cd packages/ui && bun dev"],
          "color": "terminal.ansiCyan"
        },
        {
          "name": "backend",
          "commands": ["uv run autosae-server --model-id meta-llama/Llama-3.1-8B --load-in-4bit --port 8000"],
          "color": "terminal.ansiGreen"
        }
      ]
    ]
  }
}
